# The Silla Table — environment variables (copy to .env.local)
# Local MVP works WITHOUT any of these. They are placeholders for later (Vercel) deployment.

# Inquiry (contact form) delivery — not required locally.
# When set, the /api/contact route could send via Resend. Left empty -> inquiries are logged
# to the server console and saved to ./.inquiries/*.json for local inspection.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@thesillatable.com

# Analytics — loaded only after cookie consent. Empty -> analytics disabled.
NEXT_PUBLIC_GA_ID=

# Google Maps embed URL (contact page). Empty -> a styled placeholder is shown.
NEXT_PUBLIC_MAPS_EMBED=

# Public site URL, used for canonical/sitemap/OG. Defaults to http://localhost:3000 locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
